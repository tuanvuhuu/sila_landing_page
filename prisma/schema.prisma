generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteContent {
  id   Int    @id @default(autoincrement())
  // Mã site (nhiều site dùng chung 1 DB). Dữ liệu cũ = "default".
  site String @unique @default("default")
  data String
}

model Lead {
  id          Int      @id @default(autoincrement())
  // Site mà lead này thuộc về
  site        String   @default("default")
  name        String
  phone       String
  ageGroup    String   @default("")
  // Mã sự kiện nếu lead đến từ trang /su-kien/{id} (null = đăng ký thường)
  eventId     Int?
  // Trạng thái chăm sóc: new | contacted | trial | enrolled | lost
  status      String   @default("new")
  // Nguồn quảng cáo (lấy từ link Facebook ads)
  utmSource   String   @default("")
  utmMedium   String   @default("")
  utmCampaign String   @default("")
  utmContent  String   @default("")
  utmTerm     String   @default("")
  fbclid      String   @default("")
  createdAt   DateTime @default(now())

  @@index([site])
}

model Event {
  id          Int       @id @default(autoincrement())
  // Site mà sự kiện này thuộc về
  site        String    @default("default")
  title       String
  description String    @default("")
  image       String    @default("")
  date        DateTime
  endDate     DateTime?
  location    String    @default("")
  ctaText     String    @default("Đăng ký tham gia")
  ctaLink     String    @default("#signup")
  images      String    @default("[]") // JSON array of additional image URLs
  status      String    @default("draft") // draft | published | cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([site])
}
