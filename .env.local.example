# SILA Landing Page - Local Development Environment Variables
# Copy this file to .env.local and fill in your local values

# ===== LOCAL DATABASE =====
# For local development, use SQLite
DATABASE_URL="file:./dev.db"

# ===== ADMIN CREDENTIALS (Local) =====
ADMIN_PASSWORD="doimatkhaunay"
SESSION_SECRET="local-secret-key-for-development-only-not-for-production"

# ===== LOCAL SITE URL =====
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== FACEBOOK PIXEL (Optional - can leave blank for local dev) =====
NEXT_PUBLIC_FB_PIXEL_ID=""
FB_PIXEL_ID=""
FB_CAPI_TOKEN=""

# ===== GOOGLE ANALYTICS (Optional - can leave blank for local dev) =====
GOOGLE_ANALYTICS_ID=""

# ===== EMAIL SERVICE (Optional - can leave blank for local dev) =====
RESEND_API_KEY=""
LEAD_NOTIFY_EMAIL="your-email@gmail.com"
LEAD_FROM_EMAIL="SILA Academy <onboarding@resend.dev>"

# ===== FILE UPLOAD (Optional - can leave blank for local dev) =====
BLOB_READ_WRITE_TOKEN=""

# ===== DEVELOPMENT FLAGS =====
NODE_ENV="development"
PORT=3000
ENABLE_ANALYTICS=false
MAINTENANCE_MODE=false
