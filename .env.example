# Mật khẩu đăng nhập trang admin — ĐỔI thành mật khẩu của bạn
ADMIN_PASSWORD="doimatkhaunay"

# Chuỗi bí mật dùng cho phiên đăng nhập — dán một chuỗi ngẫu nhiên thật dài
SESSION_SECRET="thay-bang-mot-chuoi-ngau-nhien-rat-dai-va-bi-mat"

# ===== FACEBOOK ADS =====
# Pixel ID — lấy trong Meta Events Manager. Bắt buộc để chạy quảng cáo.
NEXT_PUBLIC_FB_PIXEL_ID=""

# (Tùy chọn nhưng nên có) Conversions API — tracking phía máy chủ, đáng tin hơn
# FB_PIXEL_ID giống Pixel ID ở trên; FB_CAPI_TOKEN lấy ở Events Manager > Settings
FB_PIXEL_ID=""
FB_CAPI_TOKEN=""

# Giá trị 1 khách ghi danh (gửi kèm sự kiện Purchase về FB). VD học phí trung bình.
FB_PURCHASE_VALUE="0"
FB_CURRENCY="VND"

# ===== EMAIL BÁO KHÁCH MỚI (Resend) =====
# Tạo API key miễn phí ở https://resend.com. Để trống thì tính năng email tắt.
