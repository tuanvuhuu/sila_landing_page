# ===== DATABASE =====
# PostgreSQL (recommended for production)
# Local SQLite: "file:./dev.db"
# Neon PostgreSQL: "postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"
# Railway PostgreSQL: "postgresql://user:password@host:5432/db"
DATABASE_URL="postgresql://user:password@host:5432/sila_db"

# ===== MULTI-SITE SUPPORT =====
# Mỗi site dùng chung 1 database nhưng lưu dữ liệu riêng
# Để trống = "default" (dữ liệu cũ). Ví dụ site thứ 2: SITE_KEY="sila-q7"
SITE_KEY=""

# ===== ADMIN AUTHENTICATION =====
# Mật khẩu đăng nhập admin - ĐỔI thành mật khẩu của bạn
ADMIN_PASSWORD="doimatkhaunay"

# Chuỗi bí mật dùng cho session cookie - dán một chuỗi ngẫu nhiên thật dài (min 32 chars)
SESSION_SECRET="thay-bang-mot-chuoi-ngau-nhien-rat-dai-va-bi-mat-32-characters-min"

# ===== WEBSITE CONFIGURATION =====
# URL chính thức (domain) - dùng cho SEO, Open Graph, sitemap, robots
# Local: http://localhost:3000
# Production: https://sila.edu.vn
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ===== COMPANY INFORMATION =====
COMPANY_NAME=SILA
COMPANY_SLOGAN=English Center for Kids and Teens
COMPANY_EMAIL=info@sila.edu.vn
COMPANY_PHONE=(028) 1234 5678
COMPANY_ADDRESS=123 Đường ABC, Quận 1, TP. HCM
COMPANY_HOURS=Thứ 2 - 7: 8:00 - 18:00

# ===== COLOR SCHEME =====
PRIMARY_BLUE=#003D6B
SECONDARY_BLUE=#1976D2
LIGHT_BLUE=#E3F2FD
GOLD_COLOR=#FFB81C
WHITE=#FFFFFF
DARK_GRAY=#333333
LIGHT_GRAY=#F5F5F5

# ===== FACEBOOK ADS =====
